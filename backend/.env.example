# Supabase — proyecto del backend (service role, NUNCA se expone al cliente)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# TMDB — Read Access Token (no la API Key v3, sino el Bearer token v4)
TMDB_API_READ_TOKEN=eyJhbGciOiJIUzI1NiJ9...

# Email del administrador de la aplicación
ADMIN_EMAIL=admin@example.com

# Puerto del servidor (Render usa la variable PORT automáticamente)
PORT=3001
